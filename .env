# Environment variables for auth project
# PostgreSQL connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/auth_db?sslmode=disable

# Encryption key for MFA secrets (32-byte base64 or hex string)
MFA_ENCRYPTION_KEY=MTIzNDU2Nzg5MDEyMzQ1Njc4OTAxMjM0NTY3ODkwMTI=
# JWT signing key (at least 32 bytes)
JWT_SECRET=this-is-a-very-secret-jwt-key-32-chars-long

# Test mode for automated integration tests
MFA_TEST_MODE=true